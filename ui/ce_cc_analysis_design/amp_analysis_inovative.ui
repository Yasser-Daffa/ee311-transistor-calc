}

QLineEdit:focus {
    border: 1px solid #667EEA;
    background-color: #f9fafb;
}

QLineEdit:disabled {
    /* A soft, muted gray that looks non-interactive */
    background-color: #f3f4f6; 
    
    /* Mutes the text color to signal it cannot be edited */
    color: #9ca3af;            
    
    /* Softens the border so it recedes into the background */
    border: 1px solid #e5e7eb; 
}</string>
