         <property name="styleSheet">
          <string notr="true">QPushButton {
    /* Your original blue */
    background-color: rgb(34, 104, 190); 
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
}

QPushButton:hover {
    /* A slightly brighter, more vibrant version of your blue */
    background-color: rgb(46, 126, 219); 
}

QPushButton:pressed {
    /* A deeper, more saturated version for tactile feedback */
    background-color: rgb(26, 86, 161); 
}

QPushButton:disabled {
    background-color: #e2e8f0;
    color: #94a3b8;
}</string>
         </property>
         <property name="text">
          <string>Send to AC Analysis ➤</string>
         </property>
