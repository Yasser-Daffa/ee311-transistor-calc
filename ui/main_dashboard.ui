           <widget class="QScrollArea" name="scrollArea">
            <property name="styleSheet">
             <string notr="true">
/* ===== VERTICAL SCROLLBAR ===== */
QScrollBar:vertical {
    width: 12px;
    background: rgba(255, 255, 255, 0.05);  /* subtle track */
    margin: 0px 0px 0px 0;  /* TOP RIGHT BOTTOM LEFT */
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background: rgba(120, 120, 120, 0.35);  /* glassy thumb */
    border-radius: 6px;
    min-height: 30px;
    border: 1px solid rgba(255, 255, 255, 0.2); /* subtle highlight */
}

QScrollBar::handle:vertical:hover {
    background: rgba(120, 120, 120, 0.55);
}

/* Up/Down buttons */
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 16px;
    background: rgba(180, 180, 180, 0.35);
    border-radius: 4px;
}

/* Arrow icons */
QScrollBar::up-arrow:vertical,
QScrollBar::down-arrow:vertical {
    width: 6px;
    height: 6px;
    background: transparent;
}

/* Remove the blank area inside */
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}
/* ===== HORIZONTAL SCROLLBAR ===== */
QScrollBar:horizontal {
    height: 12px;
    background: rgba(255, 255, 255, 0.05);  /* subtle track */
    margin: 0px 0 0px 0;  /* TOP RIGHT BOTTOM LEFT */
    border-radius: 6px;
}

QScrollBar::handle:horizontal {
    background: rgba(120, 120, 120, 0.35);  /* glassy thumb */
    border-radius: 6px;
    min-width: 30px;
    border: 1px solid rgba(255, 255, 255, 0.2); /* subtle highlight */
}

QScrollBar::handle:horizontal:hover {
    background: rgba(120, 120, 120, 0.55);
}

/* Left/Right buttons */
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 16px;
    background: rgba(180, 180, 180, 0.35);
    border-radius: 4px;
}

/* Arrow icons */
QScrollBar::left-arrow:horizontal,
QScrollBar::right-arrow:horizontal {
    width: 6px;
    height: 6px;
    background: transparent;
}

/* Remove the blank area inside */
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}
</string>
            </property>
