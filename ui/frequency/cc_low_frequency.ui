               <string notr="true">QPushButton { background:#e8eaf6; color:#3d3d9e; border-radius:6px; font:700 9pt 'Segoe UI'; padding:6px 10px; border:none; }
QPushButton:hover { background:#6D63E8; color:white; }
QPushButton:checked { background:#6D63E8; color:white; }
QPushButton:pressed {
    /* Slightly darker than your #6D63E8 hover color */
    background-color: #5a52c7; 
    color: #f0f0f0;
    
    /* The &quot;Push&quot; effect: increase top padding, decrease bottom */
    padding-top: 8px;
    padding-bottom: 4px;
}</string>
