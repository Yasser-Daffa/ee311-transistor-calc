             <string notr="true">QLabel {
    color: rgb(80, 80, 80);                  /* soft dark gray */
    font-size: 13px;
    font-weight: 500;
    font-family: &quot;Segoe UI&quot;, &quot;Roboto&quot;, sans-serif;
}</string>
            </property>
            <property name="text">
             <string>CE LOW FREQUENCY RESPONSE

RB = R1 || R2
RXX = rπ + (β + 1)RX
RSB = RS || RB

R11 = RS + (RB || RXX)
f1 = 1 / (2π R11 C1)

R22 = RC + RL
f2 = 1 / (2π R22 C2)

REE = RE || [RX + (rπ + RSB)/(β + 1)]
fE = 1 / (2π REE CE)

max(f1, f2, fE) ≤ fL ≤ f1 + f2 + fE
Conservative: fL = max(f1, f2, fE)</string>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
