            </property>
            <property name="styleSheet">
             <string notr="true">QPushButton {
    /* Your original blue */
    background-color: rgb(34, 104, 190); 
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    padding: 5px 20px;
}

QPushButton:hover {
    /* A slightly brighter, more vibrant version of your blue */
    background-color: rgb(46, 126, 219); 
}

QPushButton:pressed {
    /* A deeper, more saturated version for tactile feedback */
    background-color: rgb(26, 86, 161); 
}

QPushButton:disabled {
    background-color: #e2e8f0;
    color: #94a3b8;
}</string>
            </property>
            <property name="text">
             <string> Show Formulas</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="labelFormulaText">
            <property name="styleSheet">
             <string notr="true">QLabel {
    color: rgb(80, 80, 80);                  /* soft dark gray */
    font-size: 13px;
    font-weight: 500;
    font-family: &quot;Segoe UI&quot;, &quot;Roboto&quot;, sans-serif;
}</string>
            </property>
            <property name="text">
             <string>R11 = Rs + (RB || RXX)
R22 = RC + RL
REE = RE || [ RX + (rπ + RSB)/(β + 1) ]

f1 = 1/(2πR11C1)
f2 = 1/(2πR22C2)
fE = 1/(2πREECE)

max(f1, f2, fE) ≤ fL ≤ f1 + f2 + fE</string>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
           </widget>
