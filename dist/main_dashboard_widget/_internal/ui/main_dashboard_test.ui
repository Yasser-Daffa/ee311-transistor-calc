           <property name="minimumSize">
            <size>
             <width>0</width>
             <height>50</height>
            </size>
           </property>
           <property name="cursor">
            <cursorShape>PointingHandCursor</cursorShape>
           </property>
           <property name="styleSheet">
            <string notr="true">QPushButton {
    background-color: #fff5f5;
    border: 2px solid #fed7d7;
    border-radius: 12px;
    color: #e53e3e;
    font-weight: 700;
    font-size: 14px;
    text-align: left;
    padding-left: 18px;
    /* Add subtle shadow for depth */
    box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.1);
}

/* Hover effect */
QPushButton:hover {
    background-color: #fed7d7;
}

/* Pressed effect */
QPushButton:pressed {
    background-color: #fbb6b6; /* slightly darker */
    padding-left: 20px;        /* move text slightly right to simulate press */
    padding-top: 2px;          /* move text slightly down */
    border-color: #f56565;     /* darker border */
}
</string>
           </property>
           <property name="text">
            <string>🚪  Logout</string>
           </property>
