           <property name="styleSheet">
            <string notr="true">QPushButton {
    background-color: transparent;
    border: none;
    border-radius: 10px;
    color: #5a6c7d;
    font-size: 14px;
    text-align: left;
    padding-left: 15px;
}

QPushButton:hover {
    background-color: #f8f9fa;
    color: #8c6fff;  /* slightly purple-ish on hover */
}

/* CHECKED / TOGGLED STATE */
QPushButton:checked {
    background-color: rgba(140, 111, 255, 0.10);  /* faint purple */
    color: #8c6fff; 
    font-weight: bold;
    border-left: 4px solid #8c6fff;
    padding-left: 11px; /* adjust so bar doesn’t push content too far */
}

/* PRESSED STATE (optional but clean) */
QPushButton:pressed {
    background-color: rgba(140, 111, 255, 0.18);  /* slightly darker purple on press */
}
</string>
           </property>
