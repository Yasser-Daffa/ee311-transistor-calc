    border-left: 4px solid #8c6fff;
    padding-left: 11px; /* adjust so bar doesn’t push content too far */
}

/* PRESSED STATE (optional but clean) */
QPushButton:pressed {
    background-color: rgba(140, 111, 255, 0.18);  /* slightly darker purple on press */
}
</string>
