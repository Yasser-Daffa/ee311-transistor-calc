        <item>
         <widget class="QPushButton" name="pushButtonShowFormulas">
          <property name="styleSheet">
           <string notr="true">QPushButton {
    /* Your original blue */
    background-color: rgb(34, 104, 190); 
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    padding: 5px 20px;
}

QPushButton:hover {
    /* A slightly brighter, more vibrant version of your blue */
    background-color: rgb(46, 126, 219); 
}

QPushButton:pressed {
    /* A deeper, more saturated version for tactile feedback */
    background-color: rgb(26, 86, 161); 
}

QPushButton:disabled {
    background-color: #e2e8f0;
    color: #94a3b8;
}</string>
          </property>
          <property name="text">
           <string>Show Formulas</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="labelFormulaText">
          <property name="styleSheet">
           <string notr="true">QLabel {
    color: rgb(80, 80, 80);                  /* soft dark gray */
    font-size: 13px;
    font-weight: 500;
    font-family: &quot;Segoe UI&quot;, &quot;Roboto&quot;, sans-serif;
}</string>
          </property>
          <property name="text">
           <string>CE–CC MULTISTAGE FREQUENCY RESPONSE

LOW FREQUENCY
RB1 = R1 || R2
RXX1 = rπ1 + (β + 1)RX1
R11 = RS + (RB1 || RXX1)

REL2 = RE2 || RL
RXX2 = rπ2 + (β + 1)REL2
Ri2 = RB2 || RXX2
R22 = RC1 + Ri2

RSB2 = RC1 || RB2
R33 = RL + { RE2 || [(rπ2 + RSB2)/(β + 1)] }

RSB1 = RS || RB1
REE = RE1 || [ RX1 + (rπ1 + RSB1)/(β + 1) ]

f1 = 1 / (2πR11C1)
f2 = 1 / (2πR22C2)
f3 = 1 / (2πR33C3)
fE = 1 / (2πREECE)

max(f1, f2, f3, fE) ≤ fL ≤ f1 + f2 + f3 + fE

HIGH FREQUENCY
RSB1 = RS || RB1
RCL1 = RC1 || Ri2
RXX1 = rπ1 + (β + 1)RX1

Rπ1 = rπ1(RSB1 + RX1) / (RSB1 + RXX1)
Rµ1 = [RXX1(RSB1 + RCL1) + (β + 1)RSB1RCL1] / (RSB1 + RXX1)

RSB2 = RC1 || RB2
REL2 = RE2 || RL
RXX2 = rπ2 + (β + 1)REL2

Rµ2 = RSB2 || RXX2
Rπ2 = rπ2 || [RSB2 + (β + 1)REL2]

fπ1 = 1 / (2πRπ1Cπ1)
fµ1 = 1 / (2πRµ1Cµ1)
fπ2 = 1 / (2πRπ2Cπ2)
fµ2 = 1 / (2πRµ2Cµ2)

fπ1 || fµ1 || fπ2 || fµ2 ≤ fH ≤ min(fπ1, fµ1, fπ2, fµ2)</string>
          </property>
          <property name="wordWrap">
           <bool>true</bool>
          </property>
         </widget>
        </item>
