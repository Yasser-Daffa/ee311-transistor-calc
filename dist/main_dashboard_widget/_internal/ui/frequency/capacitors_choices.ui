    color: #6b7280;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 14px;
    text-align: center;
}

/* Hover */
QPushButton:hover {
    background-color: #f9fafb;
    color: #667EEA;
}

/* While clicking */
QPushButton:pressed {
    background-color: transparent;
}

/* Selected (persistent state) */
QPushButton:checked {
    background-color: #e5e7eb;
    color: #374151;
    font-weight: 600;

    /* Re-stating the radius here ensures the blue line follows the bottom-right curve */
    border-bottom-right-radius: 8px;
    border-bottom: 3px solid #667EEA;
}</string>
