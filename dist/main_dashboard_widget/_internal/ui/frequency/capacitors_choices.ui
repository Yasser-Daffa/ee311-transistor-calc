        <string notr="true">QPushButton {
    background-color: #ffffff;
    border: none;
    
    /* Only the bottom-right is rounded now */
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 0px;
    border-top-left-radius: 0px;
