  <property name="styleSheet">
   <string notr="true">QWidget {
background-color: #f5f7fa;
}
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #d1d5db;
    border-radius: 5px;

    padding: 6px 8px;

    color: #111827;
    font-size: 13px;
    font-family: &quot;JetBrains Mono&quot;, &quot;Consolas&quot;, monospace;
}

QLineEdit:focus {
    border: 1px solid #667EEA;
    background-color: #f9fafb;
}
QLabel {
    color: #374151;
    font-family: &quot;Rockwell&quot;;
    font-size: 13pt;
    font-weight: bold;
    background: transparent;
    border: none;
}
QLineEdit[requiredInput=&quot;true&quot;] {
    background-color: #fdfdff;  /* Extremely light blue tint to differentiate from standard white */
    border: 1px solid #c7d2fe;  /* Soft indigo border */
    border-left: 4px solid #6D63E8; /* THE ACCENT: Uses your primary theme purple */
    border-radius: 4px;
    padding: 6px 8px;
    padding-left: 10px;         /* Extra padding to clear the accent strip */
    color: #111827;
    font-family: &quot;JetBrains Mono&quot;, monospace;
}

QLineEdit[requiredInput=&quot;true&quot;]:focus {
    background-color: #ffffff;
    border: 1px solid #6D63E8;
    border-left: 6px solid #6D63E8; /* Thicker strip on focus for high attention */
}

/* Optional: Subtle indicator if the user clears a required field */
QLineEdit[requiredInput=&quot;true&quot;][text=&quot;&quot;] {
    background-color: #fcfaff; 
}
QLineEdit:disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
    border: 1px solid #cbd5e1;
}</string>
