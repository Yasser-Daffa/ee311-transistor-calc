              <property name="styleSheet">
               <string notr="true">QPushButton { 
    background-color: white; 
    color: #6b7280; 
    font-size: 12px; 
    font-weight: 500; 
    padding: 10px 18px;
    border: 1px solid #e5e7eb; /* Subtle light gray border */
    border-right: none;        /* Hide internal borders to prevent double-thickness */
}

/* 2. ACTIVE STATE (The &quot;Selected&quot; Look) */
QPushButton:checked { 
    color: #185FA5; 
    background-color: #f0f5ff; 
    /* We use a 3px bottom border inside the button to match your preference */
    border-bottom: 3px solid #378ADD; 
}

/* 3. HOVER STATE */
QPushButton:hover:!checked { 
    color: #374151; 
    background-color: #f9fafb; 
}

/* 4. SHAPE: LEFTMOST BUTTON (Rounded on left only) */
QPushButton {
	border-top-left-radius: 12px;
    border-bottom-left-radius: 12px;
    border-top-right-radius: 0px;
    border-bottom-right-radius: 12px;
}

QPushButton:pressed {
    /* Slightly deeper blue than the checked state #f0f5ff */
    background-color: #dbeafe; 
    color: #1e293b;
    
    /* THE &quot;PUSH&quot; EFFECT: Shift text down 1px */
    padding-top: 11px;
    padding-bottom: 9px;

    border-bottom: 3px solid #378ADD;
}</string>
